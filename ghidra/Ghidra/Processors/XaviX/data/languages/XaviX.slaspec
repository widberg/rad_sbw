# sleigh specification file for MOS 6502 based XaviX Microcontroller

define endian=little;
define alignment=1;

define space lowbus   type=ram_space      size=2;
define space extbus   type=ram_space      size=3  default;
define space bankstack type=ram_space     size=1;
define space register type=register_space size=1;

define register offset=0x00 size=1 [ A X Y P ];
define register offset=0x20 size=2 [ PC SP ];
define register offset=0x20 size=1 [ PCL PCH S SH ];
define register offset=0x30 size=1 [ N V B D I Z C ]; # status bits
define register offset=0x40 size=1 [ SSP SSINIT ];
define register offset=0x42 size=1 [ VECEN NMIVL NMIVH IRQVL IRQVH VECINIT ];

define lowbus offset=0xFE size=1 [ CODE_BANK DATA_BANK ];

# TOKENS

define token opbyte (8)
  op  = (0,7)
  aaa = (5,7)
  bbb = (2,4)
  cc  = (0,1)
;

define token data8 (8)
  imm8 = (0,7)
  rel  = (0,7) signed
;

define token data (16)
  imm16    = (0,15)
  imm16msb = (15,15)
;

define token data24 (24)
  imm24hi = (0,7)
  imm24hibit = (7,7)
  imm24lo = (8,23)
  imm24lomsb = (23,23)
;

################################################################
# Helpers
################################################################

define pcodeop segment;

macro pushByte(value) {
  local spaddr:2 = zext(S) + 0x100;
  *[lowbus]:1 spaddr = value;
  S = S - 1;
}

macro popByte(out) {
  S = S + 1;
  local spaddr:2 = zext(S) + 0x100;
  out = *[lowbus]:1 spaddr;
}

macro ensureSpecialStack() {
  if (SSINIT != 0) goto <done>;
  SSP = 0xff;
  SSINIT = 1;
<done>
}

macro ensureVectorState() {
  if (VECINIT != 0) goto <done>;
  VECEN = 0;
  NMIVL = 0;
  NMIVH = 0;
  IRQVL = 0;
  IRQVH = 0;
  VECINIT = 1;
<done>
}

macro pushSpecial(value) {
  local v:1 = value;
  ensureSpecialStack();
  *[bankstack]:1 SSP = v;
  SSP = SSP - 1;
}

macro popSpecial(out) {
  ensureSpecialStack();
  SSP = SSP + 1;
  out = *[bankstack]:1 SSP;
}

macro pushWord(value) {
  local tmp:2 = value;
  pushByte(tmp >> 8);
  pushByte(tmp);
}

macro popWord(out) {
  local lo:1;
  local hi:1;
  popByte(lo);
  popByte(hi);
  out = zext(lo) | (zext(hi) << 8);
}

macro popSR() {
  local ccr:1;
  popByte(ccr);
  N = ccr[7,1];
  V = ccr[6,1];
  # MAME forces B/E high when pulling status on XaviX.
  B = 1;
  D = ccr[3,1];
  I = ccr[2,1];
  Z = ccr[1,1];
  C = ccr[0,1];
}

macro pushSR() {
  local ccr:1 = 0xff;
  ccr[7,1] = N;
  ccr[6,1] = V;
  ccr[4,1] = B;
  ccr[3,1] = D;
  ccr[2,1] = I;
  ccr[1,1] = Z;
  ccr[0,1] = C;
  pushByte(ccr);
}

macro resultFlags(value) {
  Z = (value == 0);
  N = (value s< 0);
}

macro doCMP(lhs, rhs) {
  local l:1 = lhs;
  local r:1 = rhs;
  local l2:2 = zext(l);
  local r2:2 = zext(r);
  local result:1 = l - r;
  resultFlags(result);
  C = (l2 >= r2);
}

macro doADC(rhs) {
  local l:1 = A;
  local r:1 = rhs;
  if (D == 0) goto <nd>;
  local cIn:1 = C;
  local al:2 = zext(l & 0x0f) + zext(r & 0x0f) + zext(cIn);
  if (al > 9) goto <adc_d_al_adj>;
  goto <adc_d_al_done>;
<adc_d_al_adj>
  al = al + 6;
<adc_d_al_done>
  local carryLo:1 = (al > 15);
  local ah:2 = zext(l >> 4) + zext(r >> 4) + zext(carryLo);
  local raw:2 = zext(l) + zext(r) + zext(cIn);
  Z = ((raw & 0xff) == 0);
  N = ((raw & 0xff) != 0) & ((ah & 0x08) != 0);
  local ahShiftWide:2 = ah << 4;
  local ahShift:1 = ahShiftWide[0,8];
  V = ((~(l ^ r) & (l ^ ahShift) & 0x80) != 0);
  if (ah > 9) goto <adc_d_ah_adj>;
  goto <adc_d_ah_done>;
<adc_d_ah_adj>
  ah = ah + 6;
<adc_d_ah_done>
  C = (ah > 15);
  local hiNibbleWide:2 = ah << 4;
  local hiNibble:1 = hiNibbleWide[0,8];
  local al8:1 = al[0,8];
  local loNibble:1 = al8 & 0x0f;
  A = hiNibble | loNibble;
  goto <done>;
<nd>
  local cInNd:1 = C;
  local sum:2 = zext(l) + zext(r) + zext(cInNd);
  local result:1 = l + r + cInNd;
  A = result;
  resultFlags(A);
  V = ((~(l ^ r) & (l ^ result) & 0x80) != 0);
  C = ((sum & 0x100) != 0);
<done>
}

macro doSBC(rhs) {
  local l:1 = A;
  local r:1 = rhs;
  if (D == 0) goto <nd>;
  local borrowIn:1 = !C;
  local diff:2 = zext(l) - zext(r) - zext(borrowIn);
  local al:2 = zext(l & 0x0f) - zext(r & 0x0f) - zext(borrowIn);
  if (al s< 0) goto <sbc_d_al_adj>;
  goto <sbc_d_al_done>;
<sbc_d_al_adj>
  al = al - 6;
<sbc_d_al_done>
  local alBorrow:1 = (al s< 0);
  local ah:2 = zext(l >> 4) - zext(r >> 4) - zext(alBorrow);
  Z = ((diff & 0xff) == 0);
  N = ((diff & 0x80) != 0);
  local diff8:1 = diff[0,8];
  V = (((l ^ r) & (l ^ diff8) & 0x80) != 0);
  C = ((diff & 0xff00) == 0);
  if (ah s< 0) goto <sbc_d_ah_adj>;
  goto <sbc_d_ah_done>;
<sbc_d_ah_adj>
  ah = ah - 6;
<sbc_d_ah_done>
  local hiNibbleWide:2 = ah << 4;
  local hiNibble:1 = hiNibbleWide[0,8];
  local al8:1 = al[0,8];
  local loNibble:1 = al8 & 0x0f;
  A = hiNibble | loNibble;
  goto <done>;
<nd>
  local borrowInNd:1 = !C;
  local l2:2 = zext(l);
  local r2:2 = zext(r);
  local b2:2 = zext(borrowInNd);
  local result:1 = l - r - borrowInNd;
  A = result;
  resultFlags(A);
  V = (((l ^ r) & (l ^ result) & 0x80) != 0);
  local rhs2:2 = r2 + b2;
  C = (l2 >= rhs2);
<done>
}

macro doARR() {
  if (D != 0) goto <arr_d>;
  local carryIn:1 = C;
  A = A >> 1;
  if (carryIn == 0) goto <carry_done>;
  A = A | 0x80;
<carry_done>
  resultFlags(A);
  local bit6:1 = (A & 0x40) != 0;
  local bit5:1 = (A & 0x20) != 0;
  C = bit6;
  V = (bit6 != bit5);
  goto <done>;
<arr_d>
  local carryInD:1 = C;
  local oldA:1 = A;
  local a:1 = oldA >> 1;
  C = 0;
  if (carryInD != 0) goto <arr_d_carry_in>;
  goto <arr_d_after_carry_in>;
<arr_d_carry_in>
  a = a | 0x80;
<arr_d_after_carry_in>
  Z = (a == 0);
  N = (a s< 0);
  V = (((a ^ oldA) & 0x40) != 0);
  if ((oldA & 0x0f) >= 0x05) goto <arr_d_low_adj>;
  goto <arr_d_low_done>;
<arr_d_low_adj>
  a = ((a + 6) & 0x0f) | (a & 0xf0);
<arr_d_low_done>
  if ((oldA & 0xf0) >= 0x50) goto <arr_d_carry>;
  A = a;
  goto <done>;
<arr_d_carry>
  a = a + 0x60;
  C = 1;
  A = a;
<done>
}

macro dataRead(addr, out) {
  local ea:2 = addr;
  local db:1 = DATA_BANK;
  if (db >= 0x80) goto <ext>;
  if (ea >= 0x8000) goto <ext>;
  ensureVectorState();
  if (ea == 0x7ff9) goto <read_vecen>;
  if (ea == 0x7ffa) goto <read_nmivl>;
  if (ea == 0x7ffb) goto <read_nmivh>;
  if (ea == 0x7ffe) goto <read_irqvl>;
  if (ea == 0x7fff) goto <read_irqvh>;
  out = *[lowbus]:1 ea;
  goto <done>;
<read_vecen>
  out = VECEN;
  goto <done>;
<read_nmivl>
  out = NMIVL;
  goto <done>;
<read_nmivh>
  out = NMIVH;
  goto <done>;
<read_irqvl>
  out = IRQVL;
  goto <done>;
<read_irqvh>
  out = IRQVH;
  goto <done>;
<ext>
  local ptr:3 = segment(db, ea);
  out = *:1 ptr;
<done>
}

macro dataWrite(addr, value) {
  local ea:2 = addr;
  local db:1 = DATA_BANK;
  local v:1 = value;
  if (db >= 0x80) goto <ext>;
  if (ea >= 0x8000) goto <ext>;
  ensureVectorState();
  if (ea == 0x7ff9) goto <write_vecen>;
  if (ea == 0x7ffa) goto <write_nmivl>;
  if (ea == 0x7ffb) goto <write_nmivh>;
  if (ea == 0x7ffe) goto <write_irqvl>;
  if (ea == 0x7fff) goto <write_irqvh>;
  *[lowbus]:1 ea = v;
  goto <done>;
<write_vecen>
  VECEN = v;
  goto <done>;
<write_nmivl>
  NMIVL = v;
  goto <done>;
<write_nmivh>
  NMIVH = v;
  goto <done>;
<write_irqvl>
  IRQVL = v;
  goto <done>;
<write_irqvh>
  IRQVH = v;
  goto <done>;
<ext>
  local ptr:3 = segment(db, ea);
  *:1 ptr = v;
<done>
}

macro codeRead(addr, out) {
  local ea:2 = addr;
  local cb:1 = CODE_BANK;
  if (cb >= 0x80) goto <ext>;
  if (ea >= 0x8000) goto <ext>;
  out = *[lowbus]:1 ea;
  goto <done>;
<ext>
  local ptr:3 = segment(cb, ea);
  out = *:1 ptr;
<done>
}

macro zpageRead(addr, out) {
  local ea:2 = addr & 0x00ff;
  out = *[lowbus]:1 ea;
}

macro zpageWrite(addr, value) {
  local ea:2 = addr & 0x00ff;
  local v:1 = value;
  *[lowbus]:1 ea = v;
}

macro dummyDataRead(addr) {
  local discard:1;
  dataRead(addr, discard);
}

macro dummyCodeRead(addr) {
  local discard:1;
  codeRead(addr, discard);
}

macro dummyZpageRead(addr) {
  local discard:1;
  zpageRead(addr, discard);
}

macro dummyStackRead(sp) {
  local spaddr:2 = (sp & 0x00ff) + 0x100;
  local discard:1 = *[lowbus]:1 spaddr;
}

macro zpageIndexedAddr(base, idx, out) {
  dummyZpageRead(base);
  out = zext((base + idx) & 0x00ff);
}

macro fetchZpagePointer(base, out) {
  local ptr:2 = base;
  ptr = ptr & 0x00ff;
  local lo:1 = *[lowbus]:1 ptr;
  ptr = (ptr + 1) & 0x00ff;
  local hi:1 = *[lowbus]:1 ptr;
  out = zext(lo) | (zext(hi) << 8);
}

macro dummyIndexedRead(base, indexed) {
  local spill:2 = (base & 0xff00) | (indexed & 0x00ff);
  dummyDataRead(spill);
}

macro dummyPageCrossRead(base, indexed) {
  if ((base & 0xff00) == (indexed & 0xff00)) goto <same_page>;
  dummyIndexedRead(base, indexed);
<same_page>
}

macro dummyBranchTakenReads(target) {
  local t:2 = target;
  dummyCodeRead(inst_next);
  if ((inst_next & 0xff00) == (t & 0xff00)) goto <same_page>;
  local spill:2 = (inst_next & 0xff00) | (t & 0x00ff);
  dummyCodeRead(spill);
<same_page>
}

macro writeHighMasked(base, idx, source) {
  local b:2 = base;
  local addr:2 = b + zext(idx);
  dummyIndexedRead(b, addr);
  local highPlus1:1 = b[8,8] + 1;
  local src:1 = source;
  local val:1 = src & highPlus1;
  if ((b & 0xff00) == (addr & 0xff00)) goto <same_page>;
  addr = (addr & 0x00ff) | (zext(val) << 8);
<same_page>
  dataWrite(addr, val);
}

################################################################
# Constructors
################################################################

REL: reloc is rel [ reloc = inst_next + rel; ] { export *:2 reloc; }

OP1R: "#"imm8 is bbb=2; imm8 {
  tmp:1 = imm8;
  export tmp;
}

OP1R: imm8 is bbb=1; imm8 {
  local zp:1 = imm8;
  local ea:2 = zext(zp);
  local v:1;
  zpageRead(ea, v);
  export v;
}

OP1R: imm8,X is bbb=5 & X; imm8 {
  local ea:2;
  zpageIndexedAddr(imm8, X, ea);
  local v:1;
  zpageRead(ea, v);
  export v;
}

OP1R: imm16 is bbb=3; imm16 {
  local ea:2 = imm16;
  local v:1;
  dataRead(ea, v);
  export v;
}

OP1R: imm16,X is bbb=7 & X; imm16 {
  local ea:2 = imm16 + zext(X);
  dummyPageCrossRead(imm16, ea);
  local v:1;
  dataRead(ea, v);
  export v;
}

OP1R: imm16,Y is bbb=6 & Y; imm16 {
  local ea:2 = imm16 + zext(Y);
  dummyPageCrossRead(imm16, ea);
  local v:1;
  dataRead(ea, v);
  export v;
}

OP1R: (imm8,X) is bbb=0 & X; imm8 {
  local idx:2;
  zpageIndexedAddr(imm8, X, idx);
  local ea:2;
  fetchZpagePointer(idx, ea);
  local v:1;
  dataRead(ea, v);
  export v;
}

OP1R: (imm8),Y is bbb=4 & Y; imm8 {
  local base:2;
  fetchZpagePointer(imm8, base);
  local ea:2 = base + zext(Y);
  dummyPageCrossRead(base, ea);
  local v:1;
  dataRead(ea, v);
  export v;
}

OP1MZP: imm8 is bbb=1; imm8 {
  local zp:1 = imm8;
  local ea:2 = zext(zp);
  export ea;
}

OP1MZP: imm8,X is bbb=5 & X; imm8 {
  local ea:2;
  zpageIndexedAddr(imm8, X, ea);
  export ea;
}

OP1MDB: imm16 is bbb=3; imm16 {
  local ea:2 = imm16;
  export ea;
}

OP1MDB: imm16,X is bbb=7 & X; imm16 {
  local ea:2 = imm16 + zext(X);
  dummyIndexedRead(imm16, ea);
  export ea;
}

OP1MDB: imm16,Y is bbb=6 & Y; imm16 {
  local ea:2 = imm16 + zext(Y);
  dummyIndexedRead(imm16, ea);
  export ea;
}

OP1MDB: (imm8,X) is bbb=0 & X; imm8 {
  local idx:2;
  zpageIndexedAddr(imm8, X, idx);
  local ea:2;
  fetchZpagePointer(idx, ea);
  export ea;
}

OP1MDB: (imm8),Y is bbb=4 & Y; imm8 {
  local base:2;
  fetchZpagePointer(imm8, base);
  local ea:2 = base + zext(Y);
  dummyIndexedRead(base, ea);
  export ea;
}

OP2R: "#"imm8 is bbb=0; imm8 {
  tmp:1 = imm8;
  export tmp;
}

OP2R: A is bbb=2 & A {
  export A;
}

OP2R: imm8 is bbb=1; imm8 {
  local zp:1 = imm8;
  local ea:2 = zext(zp);
  local v:1;
  zpageRead(ea, v);
  export v;
}

OP2R: imm8,X is bbb=5 & X; imm8 {
  local ea:2;
  zpageIndexedAddr(imm8, X, ea);
  local v:1;
  zpageRead(ea, v);
  export v;
}

OP2R: imm16 is bbb=3; imm16 {
  local ea:2 = imm16;
  local v:1;
  dataRead(ea, v);
  export v;
}

OP2R: imm16,X is bbb=7 & X; imm16 {
  local ea:2 = imm16 + zext(X);
  dummyPageCrossRead(imm16, ea);
  local v:1;
  dataRead(ea, v);
  export v;
}

OP2MZP: imm8 is bbb=1; imm8 {
  local zp:1 = imm8;
  local ea:2 = zext(zp);
  export ea;
}

OP2MZP: imm8,X is bbb=5 & X; imm8 {
  local ea:2;
  zpageIndexedAddr(imm8, X, ea);
  export ea;
}

OP2MDB: imm16 is bbb=3; imm16 {
  local ea:2 = imm16;
  export ea;
}

OP2MDB: imm16,X is bbb=7 & X; imm16 {
  local ea:2 = imm16 + zext(X);
  dummyIndexedRead(imm16, ea);
  export ea;
}

OP2LDR: "#"imm8 is bbb=0; imm8 {
  tmp:1 = imm8;
  export tmp;
}

OP2LDR: imm8 is bbb=1; imm8 {
  local zp:1 = imm8;
  local ea:2 = zext(zp);
  local v:1;
  zpageRead(ea, v);
  export v;
}

OP2LDR: imm8,Y is bbb=5 & Y; imm8 {
  local ea:2;
  zpageIndexedAddr(imm8, Y, ea);
  local v:1;
  zpageRead(ea, v);
  export v;
}

OP2LDR: imm16 is bbb=3; imm16 {
  local ea:2 = imm16;
  local v:1;
  dataRead(ea, v);
  export v;
}

OP2LDR: imm16,Y is bbb=7 & Y; imm16 {
  local ea:2 = imm16 + zext(Y);
  dummyPageCrossRead(imm16, ea);
  local v:1;
  dataRead(ea, v);
  export v;
}

OP2STMZP: imm8 is bbb=1; imm8 {
  local zp:1 = imm8;
  local ea:2 = zext(zp);
  export ea;
}

OP2STMZP: imm8,Y is bbb=5 & Y; imm8 {
  local ea:2;
  zpageIndexedAddr(imm8, Y, ea);
  export ea;
}

OP2STMDB: imm16 is bbb=3; imm16 {
  local ea:2 = imm16;
  export ea;
}

ADDR16LO: imm16 is imm16 & imm16msb=0 {
  tmp:2 = imm16;
  export *[lowbus]:2 tmp;
}

ADDR16HI: far is imm16 & imm16msb=1 [ far = (inst_start & 0xff0000) | imm16; ] {
  export *[extbus]:3 far;
}

ADDR24LO: far is imm24hi & imm24lo & imm24lomsb=0 [ far = (imm24hi << 16) | imm24lo; ] {
  tmp:2 = imm24lo;
  export *[lowbus]:2 tmp;
}

ADDR24LOEXT: far is imm24hi & imm24lo & imm24lomsb=0 [ far = ((imm24hi << 16) | imm24lo) & 0x3fffff; ] {
  export *[extbus]:3 far;
}

ADDR24HI: far is imm24hi & imm24lo & imm24lomsb=1 [ far = ((imm24hi << 16) | imm24lo) & 0x3fffff; ] {
  export *[extbus]:3 far;
}

ADDRI: (imm16) is imm16 {
  addr:2 = imm16;
  local lo:1;
  dataRead(addr, lo);
  local next:2 = addr + 1;
  next = (addr & 0xff00) | (next & 0x00ff);
  local hi:1;
  dataRead(next, hi);
  tmp:2 = zext(lo) | (zext(hi) << 8);
  export tmp;
}

################################################################
# Instructions
################################################################

:ADC OP1R is (cc=1 & aaa=3) ... & OP1R
{
  doADC(OP1R);
}

:AND OP1R is (cc=1 & aaa=1) ... & OP1R
{
  A = A & OP1R;
  resultFlags(A);
}

:ASL is op=0x0A
{
  local tmp:1 = A;
  C = tmp >> 7;
  tmp = tmp << 1;
  A = tmp;
  resultFlags(tmp);
}

:ASL OP2MZP is (op=0x06 | op=0x0E | op=0x16 | op=0x1E) ... & OP2MZP
{
  local ea:2 = OP2MZP;
  local opv:1;
  zpageRead(ea, opv);
  zpageWrite(ea, opv);
  C = opv >> 7;
  local tmp:1 = opv << 1;
  zpageWrite(ea, tmp);
  resultFlags(tmp);
}

:ASL OP2MDB is (op=0x06 | op=0x0E | op=0x16 | op=0x1E) ... & OP2MDB
{
  local ea:2 = OP2MDB;
  local opv:1;
  dataRead(ea, opv);
  dataWrite(ea, opv);
  C = opv >> 7;
  local tmp:1 = opv << 1;
  dataWrite(ea, tmp);
  resultFlags(tmp);
}

:BCC REL is op=0x90; REL
{
  if (C == 0) goto <taken>;
  goto <done>;
<taken>
  dummyBranchTakenReads(REL);
  goto REL;
<done>
}

:BCS REL is op=0xB0; REL
{
  if (C) goto <taken>;
  goto <done>;
<taken>
  dummyBranchTakenReads(REL);
  goto REL;
<done>
}

:BEQ REL is op=0xF0; REL
{
  if (Z) goto <taken>;
  goto <done>;
<taken>
  dummyBranchTakenReads(REL);
  goto REL;
<done>
}

:BIT OP2R is (op=0x24 | op=0x2C) ... & OP2R
{
  local op2:1 = OP2R;
  N = (op2 & 0x80) == 0x80;
  V = (op2 & 0x40) == 0x40;
  Z = ((A & op2) == 0);
}

:BMI REL is op=0x30; REL
{
  if (N) goto <taken>;
  goto <done>;
<taken>
  dummyBranchTakenReads(REL);
  goto REL;
<done>
}

:BNE REL is op=0xD0; REL
{
  if (Z == 0) goto <taken>;
  goto <done>;
<taken>
  dummyBranchTakenReads(REL);
  goto REL;
<done>
}

:BPL REL is op=0x10; REL
{
  if (N == 0) goto <taken>;
  goto <done>;
<taken>
  dummyBranchTakenReads(REL);
  goto REL;
<done>
}

:BRK is op=0x00
{
  # Models explicit BRK opcode behavior (not asynchronous IRQ entry).
  dummyCodeRead(inst_next);
  local savedBank:1 = CODE_BANK;
  pushSpecial(savedBank);
  # BRK pushes PC+2 on 6502-family cores.
  local retpc:2 = inst_next + 1;
  pushWord(retpc);
  B = 1;
  pushSR();
  I = 1;
  CODE_BANK = 0;
  # XaviX supports custom vectors via callback-backed vector state.
  ensureVectorState();
  local inner:2;
  # NOTE: MAME can redirect BRK to NMI in the nmi_pending race window.
  # SLEIGH has no dynamic nmi_pending/irq_taken state, so BRK always uses IRQ.
  if (VECEN != 0) goto <use_custom_irq_vector>;
  local romBank:1 = 0;
  local vectorAddr:2 = 0xfffe;
  local target:3 = segment(romBank, vectorAddr);
  inner = *:2 target;
  goto <dispatch_vector>;
<use_custom_irq_vector>
  local vlo:1 = IRQVL;
  local vhi:1 = IRQVH;
  inner = zext(vlo) | (zext(vhi) << 8);
<dispatch_vector>
  if ((inner & 0x8000) == 0) goto <dispatch_low>;
  ptr:3 = segment(CODE_BANK, inner);
  goto [ptr];
<dispatch_low>
  goto [inner];
}

:BVC REL is op=0x50; REL
{
  if (V == 0) goto <taken>;
  goto <done>;
<taken>
  dummyBranchTakenReads(REL);
  goto REL;
<done>
}

:BVS REL is op=0x70; REL
{
  if (V) goto <taken>;
  goto <done>;
<taken>
  dummyBranchTakenReads(REL);
  goto REL;
<done>
}


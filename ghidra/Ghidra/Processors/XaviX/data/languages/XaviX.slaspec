:LAX imm8,Y is op=0xB7 & Y; imm8
{
  local ea:2;
  zpageIndexedAddr(imm8, Y, ea);
  local val:1;
  zpageRead(ea, val);
  A = val;
  X = val;
  resultFlags(A);
}

:LAX imm16,Y is op=0xBF & Y; imm16
{
  local ea:2 = imm16 + zext(Y);
  dummyPageCrossRead(imm16, ea);
  local val:1;
  dataRead(ea, val);
  A = val;
  X = val;
  resultFlags(A);
}

:SAX (imm8,X) is op=0x83 & X; imm8
{
  local idx:2;
  zpageIndexedAddr(imm8, X, idx);
  local ea:2;
  fetchZpagePointer(idx, ea);
  local val:1 = A & X;
  dataWrite(ea, val);
}

:SAX imm8 is op=0x87; imm8
{
  local zp:1 = imm8;
  local addr:2 = zext(zp);
  local a:1 = A;
  local x:1 = X;
  local val:1 = a & x;
  zpageWrite(addr, val);
}

:SAX imm16 is op=0x8F; imm16
{
  local addr:2 = imm16;
  local a:1 = A;
  local x:1 = X;
  local val:1 = a & x;
  dataWrite(addr, val);
}

:SAX imm8,Y is op=0x97 & Y; imm8
{
  local addr:2;
  zpageIndexedAddr(imm8, Y, addr);
  local val:1 = A & X;
  zpageWrite(addr, val);
}

:ANC "#"imm8 is (op=0x0B | op=0x2B); imm8
{
  A = A & imm8;
  resultFlags(A);
  C = N;
}

:ANE "#"imm8 is op=0x8B; imm8
{
  A = A & X & imm8;
  resultFlags(A);
}

:ASR "#"imm8 is op=0x4B; imm8
{
  local tmp:1 = A & imm8;
  C = tmp & 1;
  A = tmp >> 1;
  Z = (A == 0);
  N = 0;
}

:ARR "#"imm8 is op=0x6B; imm8
{
  A = A & imm8;
  doARR();
}

:LAS OP1R is op=0xBB ... & OP1R
{
  local val:1 = OP1R;
  A = val | 0x51;
  X = 0xFF;
  resultFlags(val);
}

:LXA "#"imm8 is op=0xAB; imm8
{
  A = imm8;
  X = imm8;
  resultFlags(A);
}

:SBX "#"imm8 is op=0xCB; imm8
{
  local rhs:1 = imm8;
  local a:1 = A;
  local x:1 = X;
  local ax:1 = a & x;
  local ax2:2 = zext(ax);
  local rhs2:2 = zext(rhs);
  C = (ax2 >= rhs2);
  X = ax - rhs;
  resultFlags(X);
}

:SHA (imm8),Y is op=0x93 & Y; imm8
{
  local base:2;
  fetchZpagePointer(imm8, base);
  writeHighMasked(base, Y, A & X);
}

:SHA imm16,Y is op=0x9F & Y; imm16
{
  local base:2 = imm16;
  writeHighMasked(base, Y, A & X);
}

:SHS imm16,Y is op=0x9B & Y; imm16
{
  S = A & X;
  local base:2 = imm16;
  writeHighMasked(base, Y, S);
}

:SHX imm16,Y is op=0x9E & Y; imm16
{
  local base:2 = imm16;
  writeHighMasked(base, Y, X);
}

:SHY imm16,X is op=0x9C & X; imm16
{
  local base:2 = imm16;
  writeHighMasked(base, X, Y);
}

:KIL is (op=0x02 | op=0x12 | op=0x32 | op=0x42 | op=0x52 | op=0x62 | op=0x72 | op=0x92 | op=0xB2 | op=0xD2 | op=0xF2)
{
  # MAME kil_non performs fixed reads then deadlocks, repeatedly reading 0xffff.
  # Match the initial read_pc(); PC++; transition before deadlock.
  dummyCodeRead(inst_next);
  PC = inst_next + 1;
  dummyDataRead(0xffff);
  dummyDataRead(0xfffe);
  dummyDataRead(0xfffe);
<kil_spin>
  dummyDataRead(0xffff);
  goto <kil_spin>;
}


:CALLF ADDR24LO is op=0x22; ADDR24LO & imm24hi & imm24hibit=0
{
  dummyStackRead(SP);
  pushSpecial(CODE_BANK);
  pushWord(inst_next - 1);
  CODE_BANK = imm24hi;
  call ADDR24LO;
}

:CALLF ADDR24LOEXT is op=0x22; ADDR24LOEXT & imm24hi & imm24hibit=1
{
  dummyStackRead(SP);
  pushSpecial(CODE_BANK);
  pushWord(inst_next - 1);
  CODE_BANK = imm24hi;
  call ADDR24LOEXT;
}

:CALLF ADDR24HI is op=0x22; ADDR24HI & imm24hi
{
  dummyStackRead(SP);
  pushSpecial(CODE_BANK);
  pushWord(inst_next - 1);
  CODE_BANK = imm24hi;
  call ADDR24HI;
}

:RETF is op=0x80
{
  dummyCodeRead(inst_next);
  dummyStackRead(SP);
  local inner:2;
  local base:1;
  popWord(inner);
  popSpecial(base);
  CODE_BANK = base;
  dummyCodeRead(inner);
  inner = inner + 1;
  if (base >= 0x80) goto <retf_ext>;
  if ((inner & 0x8000) == 0) goto <retf_low>;
<retf_ext>
  res:3 = segment(base, inner);
  return [res];
<retf_low>
  return [inner];
}


:JMP ADDR16LO is op=0x4C; ADDR16LO
{
  if (CODE_BANK < 0x80) goto ADDR16LO;
  local ptr:3 = segment(CODE_BANK, ADDR16LO);
  goto [ptr];
}

:JMP ADDR16HI is op=0x4C; ADDR16HI
{
  goto ADDR16HI;

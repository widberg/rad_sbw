  if ((inner & 0x8000) == 0) goto <jmpi_low>;
<jmpi_ext>
  local ptr:3 = segment(CODE_BANK, inner);
  goto [ptr];
<jmpi_low>
  goto [inner];
}

:JSR ADDR16LO is op=0x20; ADDR16LO
{
  dummyStackRead(SP);
  pushWord(inst_next - 1);
  if (CODE_BANK < 0x80) goto <jsr_abs_lo_near>;
  local ptr:3 = segment(CODE_BANK, ADDR16LO);
  call [ptr];
  goto <jsr_abs_lo_done>;
<jsr_abs_lo_near>
  call ADDR16LO;
<jsr_abs_lo_done>
}

:JSR ADDR16HI is op=0x20; ADDR16HI
{

:RTI is op=0x40
{
  dummyCodeRead(inst_next);
  dummyStackRead(SP);
  local inner:2;
  local base:1;
  popSR();
  popWord(inner);
  popSpecial(base);
  CODE_BANK = base;
  if (base >= 0x80) goto <rti_ext>;
  if ((inner & 0x8000) == 0) goto <rti_low>;
<rti_ext>
  res:3 = segment(base, inner);
  return [res];
<rti_low>
  return [inner];
}

:RTS is op=0x60
{
  dummyCodeRead(inst_next);
  dummyStackRead(SP);
  local inner:2;
  popWord(inner);
  dummyCodeRead(inner);
  inner = inner + 1;
  if (CODE_BANK >= 0x80) goto <rts_ext>;
  if ((inner & 0x8000) == 0) goto <rts_low>;
<rts_ext>
  res:3 = segment(CODE_BANK, inner);
  return [res];
<rts_low>
  return [inner];
}

